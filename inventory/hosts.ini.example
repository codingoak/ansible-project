# Single server
[managed]
managed-node-01 ansible_host=192.168.1.100

# Group with multiple servers (example)
# [webservers]
# web01 ansible_host=192.168.1.101
# web02 ansible_host=192.168.1.102

# Variables for all servers in this group
[managed:vars]
ansible_user=ansible
ansible_python_interpreter=/usr/bin/python3
